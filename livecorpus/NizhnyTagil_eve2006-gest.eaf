    <TIER ANNOTATOR="sanya135" DEFAULT_LOCALE="ru"
        LINGUISTIC_TYPE_REF="utterance" PARTICIPANT="@eve2006m" TIER_ID="text@eve2006m">
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a2"
                TIME_SLOT_REF1="ts2" TIME_SLOT_REF2="ts18">
                <ANNOTATION_VALUE>русский язык мне возможно нравился до периода когда нас начали готовить к ОГЭ и ЕГЭ</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a3"
                TIME_SLOT_REF1="ts19" TIME_SLOT_REF2="ts31">
                <ANNOTATION_VALUE>потому что там потом неприязнь стала возникать к этому всему</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a4"
                TIME_SLOT_REF1="ts32" TIME_SLOT_REF2="ts55">
                <ANNOTATION_VALUE>как вынужденность вынужденность она пораждает эээ какой-то ааа оторжение у тебя из-под палки заставляют это делать</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a5"
                TIME_SLOT_REF1="ts56" TIME_SLOT_REF2="ts67">
                <ANNOTATION_VALUE>мне это не особо нравилось но раньше мне нравилось </ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a17"
                TIME_SLOT_REF1="ts68" TIME_SLOT_REF2="ts69">
                <ANNOTATION_VALUE>с людьми разными с иностранцами когда там на слайде нам какое-то грамматическое правило показывали мне нравилось находить системы вот так вот системно получается что вот в этом случае такое такая-то буква в этом случае такая вот</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a6"
                TIME_SLOT_REF1="ts70" TIME_SLOT_REF2="ts110">
                <ANNOTATION_VALUE>находить когда там на слайде нам какое-то грамматическое правило показывали мне нравилось находить системы вот так вот системно получается что вот в этом случае такое такая-то буква в этом случае такая вот</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a8"
                TIME_SLOT_REF1="ts111" TIME_SLOT_REF2="ts118">
                <ANNOTATION_VALUE>мне вот эта штука нравилась</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a9"
                TIME_SLOT_REF1="ts120" TIME_SLOT_REF2="ts132">
                <ANNOTATION_VALUE>возможно это из-за моего интереса в принципе к лингвистике</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a10"
                TIME_SLOT_REF1="ts133" TIME_SLOT_REF2="ts140">
                <ANNOTATION_VALUE>по поводу других вещей мне нравился также</ANNOTATION_VALUE>
            </ALIGNABLE_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <ALIGNABLE_ANNOTATION ANNOTATION_ID="a11"
                TIME_SLOT_REF1="ts141" TIME_SLOT_REF2="ts144">
